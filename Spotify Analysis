-- For this project, I downloaded Spotify data from Kaggle and used SQL to analyze song popularity, danceability, energy, and other audio features of the top 50 songs of 2021.

-- Creating the Spotify data table
CREATE TABLE BIT_DB.Spotifydata (
id integer PRIMARY KEY,
artist_name varchar NOT NULL,
track_name varchar NOT NULL,
track_id varchar NOT NULL,
popularity integer NOT NULL,
danceability decimal(4,3) NOT NULL,
energy decimal(4,3) NOT NULL,
song_key integer NOT NULL,
loudness decimal(5,3) NOT NULL,
song_mode integer NOT NULL,
speechiness decimal(5,4) NOT NULL,
acousticness decimal(6,5) NOT NULL,
instrumentalness decimal(8,7) NOT NULL,
liveness decimal(5,4) NOT NULL,
valence decimal(4,3) NOT NULL,
tempo decimal(6,3) NOT NULL,
duration_ms integer NOT NULL,
time_signature integer NOT NULL);

-- Quick look at the data
SELECT *
FROM BIT_DB.Spotifydata
LIMIT 5;

-- Top 10 most popular songs and their artists
SELECT artist_name,
    track_name,
    popularity
FROM BIT_DB.Spotifydata
ORDER BY popularity DESC
LIMIT 10;

-- Average danceability by artist, ranked highest to lowest
SELECT artist_name,
    AVG(danceability) AS avg_danceability
FROM BIT_DB.Spotifydata
GROUP BY artist_name
ORDER BY avg_danceability DESC;

-- Artist with the most songs in the top 50
SELECT artist_name,
    COUNT(track_name) AS num_songs
FROM BIT_DB.Spotifydata
GROUP BY artist_name
ORDER BY num_songs DESC
LIMIT 5;

-- Average tempo by artist, ranked highest to lowest
SELECT artist_name,
    ROUND(AVG(tempo), 2) AS avg_tempo
FROM BIT_DB.Spotifydata
GROUP BY artist_name
ORDER BY avg_tempo DESC;

-- Top 10 songs with the highest valence, ranked happiest to saddest
SELECT artist_name,
    track_name,
    valence
FROM BIT_DB.Spotifydata
ORDER BY valence DESC
LIMIT 10;

-- Top 10 longest songs and their artists
SELECT artist_name,
    track_name,
    duration_ms
FROM BIT_DB.Spotifydata
WHERE artist_name <> ''
ORDER BY duration_ms DESC
LIMIT 10;

-- Artist with the longest song
SELECT artist_name,
    track_name,
    MAX(duration_ms) AS longest_song
FROM BIT_DB.Spotifydata;
